<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="SettingsCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:background">@drawable/bg_card_white_rounded</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:paddingVertical">4dp</item>
    </style>
    <style name="InteractiveDayText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:paddingVertical">6dp</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
</resources>