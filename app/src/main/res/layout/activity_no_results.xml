<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_beige"
    tools:context=".features.Search.NoResultsActivity">

    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/menu_icn" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/health_assistant"
            android:textColor="@color/primary_green"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="serif" /> <com.google.android.material.imageview.ShapeableImageView
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_alignParentEnd="true"
        android:src="@drawable/outline_account_circle"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/CircleImageStyle" />
    </RelativeLayout>

    <EditText
        android:id="@+id/etSearchNoResults"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/search_input_bg"
        android:drawableStart="@drawable/searching_ic"
        android:drawableEnd="@drawable/ic_close"
        android:drawablePadding="12dp"
        android:hint="@string/gluten_free_remedies"
        android:paddingHorizontal="20dp"
        android:inputType="text"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="30dp"
        android:paddingVertical="10dp"
        app:layout_constraintBottom_toTopOf="@+id/btnTryAgain"
        app:layout_constraintTop_toBottomOf="@id/etSearchNoResults">

        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="20dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/white_circle_bg"
                android:elevation="6dp" />

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:elevation="6dp"
                android:src="@drawable/ic_leaf" />

            <ImageView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="10dp"
                android:background="@drawable/white_circle_bg"
                android:elevation="8dp"
                android:padding="10dp"
                android:src="@drawable/searching_ic" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/no_results_found"
            android:textColor="@color/black"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="serif" /> <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="@string/noResParagraph"
        android:textColor="@color/black"
        android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:text="@string/suggested_topics"
            android:letterSpacing="0.1"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold" />

<!--        <com.google.android.material.chip.ChipGroup-->
<!--            android:layout_width="wrap_content"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginTop="16dp"-->
<!--            app:chipSpacingHorizontal="8dp">-->

<!--            <com.google.android.material.chip.Chip-->
<!--                style="@style/Widget.MaterialComponents.Chip.Action"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="Mindfulness"-->
<!--                app:chipBackgroundColor="@color/chip_background"-->
<!--                app:chipCornerRadius="20dp"-->
<!--                app:chipStrokeWidth="0dp" />-->

<!--            <com.google.android.material.chip.Chip-->
<!--                style="@style/Widget.MaterialComponents.Chip.Action"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="Sleep Hygiene"-->
<!--                app:chipBackgroundColor="@color/chip_background"-->
<!--                app:chipCornerRadius="20dp"-->
<!--                app:chipStrokeWidth="0dp" />-->

<!--            <com.google.android.material.chip.Chip-->
<!--                style="@style/Widget.MaterialComponents.Chip.Action"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="Nutrition"-->
<!--                app:chipBackgroundColor="@color/chip_background"-->
<!--                app:chipCornerRadius="20dp"-->
<!--                app:chipStrokeWidth="0dp" />-->

<!--        </com.google.android.material.chip.ChipGroup>-->
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTryAgain"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="16dp"
        android:text="@string/try_a_different_keyword"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="@color/white"
        app:backgroundTint="@color/primary_green"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toTopOf="@+id/tvClearFilters" />

    <TextView
        android:id="@+id/tvClearFilters"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:text="@string/clear_all_filters"
        android:textColor="@color/primary_green"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
