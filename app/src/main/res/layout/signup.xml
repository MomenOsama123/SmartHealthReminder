<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_beige">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:src="@drawable/bg_logo_circle" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_account_title"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_gravity="center"
            android:layout_marginTop="16dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_account_subtitle"
            android:textSize="14sp"
            android:textColor="@color/hint_gray"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Full Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/full_name_label"
            android:textColor="@color/text_dark"
            android:layout_marginTop="12dp" />
        <EditText
            android:id="@+id/full_name_input"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/et_shape"
            android:backgroundTint="@color/white"
            android:hint="@string/full_name_hint"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/hint_gray"
            android:inputType="textPersonName"
            android:paddingStart="16dp"
            android:drawableStart="@drawable/outline_account_circle"
            android:drawablePadding="10dp"
            android:drawableTint="@color/primary_green"/>

        <!-- UserName -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/username"
            android:textColor="@color/text_dark"
            android:layout_marginTop="12dp" />
        <EditText
            android:id="@+id/username_input"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/et_shape"
            android:backgroundTint="@color/white"
            android:hint="John_Doe.11"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/hint_gray"
            android:inputType="textPersonName"
            android:paddingStart="16dp"
            android:drawableStart="@drawable/outline_account_circle"
            android:drawablePadding="10dp"
            android:drawableTint="@color/primary_green"/>

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/email_label"
            android:textColor="@color/text_dark"
            android:layout_marginTop="12dp" />
        <EditText
            android:id="@+id/email_input"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/et_shape"
            android:backgroundTint="@color/white"
            android:hint="@string/email_hint"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/hint_gray"
            android:inputType="textEmailAddress"
            android:paddingStart="16dp"/>

        <!-- Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/password_label"
            android:textColor="@color/text_dark"
            android:layout_marginTop="12dp" />
        <EditText
            android:id="@+id/password_input"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/et_shape"
            android:backgroundTint="@color/white"
            android:hint="@string/password_hint"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/hint_gray"
            android:textSize="16sp"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:drawableEnd="@drawable/ic_visibility"
            android:drawablePadding="10dp"
            android:drawableTint="@color/primary_green"
            android:gravity="start|center_vertical"/>

        <!-- Confirm Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/confirm_password_label"
            android:textColor="@color/text_dark"
            android:layout_marginTop="12dp" />
        <EditText
            android:id="@+id/confirm_password_input"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/et_shape"
            android:backgroundTint="@color/white"
            android:hint="@string/confirm_password_hint"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/hint_gray"
            android:textSize="16sp"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:drawableStart="@drawable/outline_check_circle"
            android:drawablePadding="10dp"
            android:drawableTint="@color/primary_green"/>

        <!-- Terms -->
        <CheckBox
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/terms_text"
            android:textColor="@color/text_dark" />

        <!-- Sign Up Button -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/primary_green"
            android:text="@string/signup_button"
            android:textColor="@color/white"
            android:backgroundTintMode="src_in"/>

        <!-- Already Account & Dark Mode -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/alreadyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/already_account"
                android:textColor="@color/text_dark"
                android:layout_centerHorizontal="true"/>

            <ImageView
                android:id="@+id/icDarkMode"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_dark_mode"
                android:layout_alignParentEnd="true"
                android:clickable="true"
                android:focusable="true"/>

        </RelativeLayout>

        <!-- Login -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_text"
            android:textColor="@color/primary_green"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</ScrollView>