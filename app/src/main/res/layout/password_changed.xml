<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F5F5EE"
    android:orientation="vertical"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingTop="48dp"
    android:paddingBottom="48dp">

    <!-- Back Arrow -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/arrow_back"
        android:clickable="true"
        android:focusable="true" />

    <!-- Center Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Success Icon Circle -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/check_mark_password">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:src="@drawable/check_mark_password"
                />

        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/password_changed_successfully"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A2E2A"
            android:gravity="center"
            android:fontFamily="@font/poppins_bold" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/password_reset_successfully"
            android:textSize="14sp"
            android:textColor="#6B7B75"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:fontFamily="@font/poppins_regular" />

        <!-- Back to Login Button -->

        <ImageView
            android:id="@+id/ivEcgLine"
            android:layout_width="182dp"
            android:layout_height="50dp"
            android:alpha="0.4"
            android:scaleType="fitXY"
            android:src="@drawable/ic_ecg_line" />

        <Button
            android:id="@+id/btnBackToLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/et_shape"
            android:fontFamily="@font/poppins_medium"
            android:letterSpacing="0.04"
            android:text="@string/back_to_login"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary" />

    </LinearLayout>

    <!-- ECG Line at Bottom -->

</LinearLayout>