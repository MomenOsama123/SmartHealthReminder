<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".features.settings.SettingsFragment">

    <ScrollView
        android:id="@+id/settingsScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawablePadding="14dp"
                android:gravity="center_vertical"
                android:text="@string/settings"
                android:textColor="@color/text_dark"
                android:textSize="28sp"
                android:textStyle="bold"
                app:drawableStartCompat="@drawable/ic_settings"
                app:drawableTint="@color/text_dark" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_description"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/reminders_and_alarms"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsRow">

                    <ImageView
                        style="@style/SettingsIcon"
                        android:src="@drawable/ic_notifications"
                        android:contentDescription="@null" />

                    <LinearLayout style="@style/SettingsTextGroup">

                        <TextView
                            style="@style/SettingsTitle"
                            android:text="@string/notifications" />

                        <TextView
                            style="@style/SettingsSubtitle"
                            android:text="@string/notifications_desc" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_notifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <LinearLayout style="@style/SettingsRow">

                    <ImageView
                        style="@style/SettingsIcon"
                        android:src="@drawable/ic_vibration"
                        android:contentDescription="@null" />

                    <LinearLayout style="@style/SettingsTextGroup">

                        <TextView
                            style="@style/SettingsTitle"
                            android:text="@string/alarm_vibration" />

                        <TextView
                            style="@style/SettingsSubtitle"
                            android:text="@string/alarm_vibration_desc" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_vibration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/alarm_vibration" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <LinearLayout style="@style/SettingsRow">

                    <ImageView
                        style="@style/SettingsIcon"
                        android:src="@drawable/ic_clock"
                        android:contentDescription="@null" />

                    <LinearLayout style="@style/SettingsTextGroup">

                        <TextView
                            style="@style/SettingsTitle"
                            android:text="@string/early_reminders" />

                        <TextView
                            style="@style/SettingsSubtitle"
                            android:text="@string/early_reminders_desc" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_early_reminders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <LinearLayout
                    android:id="@+id/row_alarm_snooze"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        style="@style/SettingsIcon"
                        android:src="@drawable/ic_snooze"
                        android:contentDescription="@null" />

                    <LinearLayout style="@style/SettingsTextGroup">

                        <TextView
                            style="@style/SettingsTitle"
                            android:text="@string/settings_alarm_snooze_title" />

                        <TextView
                            style="@style/SettingsSubtitle"
                            android:text="@string/settings_alarm_snooze_subtitle" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_alarm_snooze_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        tools:text="10 min" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <LinearLayout
                    android:id="@+id/row_reminder_snooze"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        style="@style/SettingsIcon"
                        android:src="@drawable/ic_snooze"
                        android:contentDescription="@null" />

                    <LinearLayout style="@style/SettingsTextGroup">

                        <TextView
                            style="@style/SettingsTitle"
                            android:text="@string/settings_reminder_snooze_title" />

                        <TextView
                            style="@style/SettingsSubtitle"
                            android:text="@string/settings_reminder_snooze_subtitle" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_reminder_snooze_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        tools:text="10 min" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <LinearLayout
                    android:id="@+id/row_exact_alarm"
                    style="@style/SettingsRow"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        style="@style/SettingsIcon"
                        android:src="@drawable/ic_bell"
                        android:contentDescription="@null" />

                    <LinearLayout style="@style/SettingsTextGroup">

                        <TextView
                            style="@style/SettingsTitle"
                            android:text="@string/exact_alarm_permission" />

                        <TextView
                            style="@style/SettingsSubtitle"
                            android:text="@string/exact_alarm_permission_desc" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="@null"
                        app:tint="@color/text_secondary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <LinearLayout
                    android:id="@+id/row_physical_activity"
                    style="@style/SettingsRow"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        style="@style/SettingsIcon"
                        android:src="@drawable/walking"
                        android:contentDescription="@null" />

                    <LinearLayout style="@style/SettingsTextGroup">

                        <TextView
                            style="@style/SettingsTitle"
                            android:text="@string/physical_activity_permission" />

                        <TextView
                            style="@style/SettingsSubtitle"
                            android:text="@string/physical_activity_permission_desc" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="@null"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/app_settings_label"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsRow">

                    <ImageView
                        style="@style/SettingsIcon"
                        android:src="@drawable/ic_dark_mode"
                        android:contentDescription="@null" />

                    <LinearLayout style="@style/SettingsTextGroup">

                        <TextView
                            style="@style/SettingsTitle"
                            android:text="@string/appearance" />

                        <TextView
                            style="@style/SettingsSubtitle"
                            android:text="@string/appearance_desc" />
                    </LinearLayout>

                    <Spinner
                        android:id="@+id/spinner_theme_mode"
                        android:layout_width="112dp"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:spinnerMode="dropdown" />
                </LinearLayout>
            </LinearLayout>            <LinearLayout style="@style/SettingsCard">

                <LinearLayout style="@style/SettingsRow">

                    <ImageView
                        style="@style/SettingsIcon"
                        android:src="@drawable/language"
                        android:contentDescription="@null" />

                    <LinearLayout style="@style/SettingsTextGroup">

                        <TextView
                            style="@style/SettingsTitle"
                            android:text="@string/language" />

                        <TextView
                            style="@style/SettingsSubtitle"
                            android:text="@string/language_desc" />
                    </LinearLayout>

                    <Spinner
                        android:id="@+id/spinner_language"
                        android:layout_width="112dp"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:spinnerMode="dropdown" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/card_about"
                style="@style/SettingsCard"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout style="@style/SettingsRow">

                    <ImageView
                        style="@style/SettingsIcon"
                        android:src="@drawable/ic_priority"
                        android:contentDescription="@null"
                        app:tint="@color/primary" />

                    <LinearLayout style="@style/SettingsTextGroup">

                        <TextView
                            style="@style/SettingsTitle"
                            android:text="@string/about_trusta" />

                        <TextView
                            style="@style/SettingsSubtitle"
                            android:text="@string/about_trusta_desc" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="@null"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="28dp"
                android:layout_marginHorizontal="24dp"
                android:text="@string/log_out"
                android:textAllCaps="false"
                android:textColor="@color/missed"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="?attr/colorSurface"
                app:cornerRadius="12dp"
                app:strokeColor="@color/missed"
                app:strokeWidth="2dp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
