<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/back_for_add_rem"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/reminders"
                android:textAppearance="@style/TextHeading3"/>

            <ImageButton
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_notifications"
                android:contentDescription="@string/notifications"/>

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_required"
                android:textAppearance="@style/TextCaption"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/set_a_new_health_goal"
                android:textAppearance="@style/TextHeading2"
                android:layout_marginBottom="24dp"/>

            <!-- Title Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title1"
                android:textAppearance="@style/TextBody2"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:hint="@string/e_g_morning_vitamins"
                android:paddingHorizontal="16dp"
                android:textAppearance="@style/TextBody1"
                android:layout_marginBottom="20dp"
                tools:ignore="Autofill,TextFields" />

            <!-- Description Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/description"
                android:textAppearance="@style/TextBody2"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_input_field"
                android:hint="@string/add_specific_instructions_or_notes"
                android:padding="16dp"
                android:textAppearance="@style/TextBody1"
                android:gravity="top"
                android:layout_marginBottom="20dp"
                tools:ignore="Autofill,TextFields" />

            <!-- Category -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category"
                android:textAppearance="@style/TextBody2"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_marginBottom="20dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_medicine"
                    style="@style/Widget.App.Chip.Selectable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/medicine"
                    app:chipIcon="@drawable/ic_medicine"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_appointment"
                    style="@style/Widget.App.Chip.Selectable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/appointment"
                    app:chipIcon="@drawable/ic_appointment"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_task"
                    style="@style/Widget.App.Chip.Selectable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/task"
                    app:chipIcon="@drawable/ic_task"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_custom"
                    style="@style/Widget.App.Chip.Selectable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/custom"
                    app:chipIcon="@drawable/ic_custom"/>

            </com.google.android.material.chip.ChipGroup>

            <!-- Date & Time -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/date_amp_time"
                android:textAppearance="@style/TextCaption"
                android:textAllCaps="true"
                android:layout_marginBottom="12dp"
                tools:ignore="AllCaps" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/et_date"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="@string/mm_dd_yyyy"
                    android:paddingHorizontal="16dp"
                    android:textAppearance="@style/TextBody1"
                    android:drawableEnd="@drawable/ic_calendar"
                    android:drawableTint="@color/text_tertiary"
                    tools:ignore="Autofill,TextFields"
                    android:focusable="true"
                    android:clickable="true"
                    android:cursorVisible="false"/>

                <EditText
                    android:id="@+id/et_time"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="@string/for_time"
                    android:paddingHorizontal="16dp"
                    android:textAppearance="@style/TextBody1"
                    android:drawableEnd="@drawable/ic_clock"
                    android:drawableTint="@color/text_tertiary"
                    tools:ignore="Autofill,TextFields"
                    android:focusable="true"
                    android:clickable="true"
                    android:cursorVisible="false"/>

            </LinearLayout>

            <!-- Recurrence -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recurrence"
                android:textAppearance="@style/TextCaption"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/row_recurrence"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_field"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_recurrence_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/none"
                    android:textAppearance="@style/TextBody1"/>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/text_tertiary"
                    android:contentDescription="@string/select_recurrence"/>

            </LinearLayout>

            <!-- Priority Level -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/priority_level"
                android:textAppearance="@style/TextBody2"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_priority"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:checkedButton="@id/btn_medium"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_low"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/low"
                    android:textAppearance="@style/TextBody1"
                    app:strokeColor="@color/border"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_medium"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/medium"
                    android:textAppearance="@style/TextBody1"
                    app:strokeColor="@color/border"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_high"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/high"
                    android:textAppearance="@style/TextBody1"
                    app:strokeColor="@color/border"/>

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Early Notification -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_notifications"
                    app:tint="@color/text_secondary"
                    android:contentDescription="@string/notification"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/early_notification"
                        android:textAppearance="@style/TextBody1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/remind_me_before_the_event"
                        android:textAppearance="@style/TextCaption"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/_5_min"
                    android:textAppearance="@style/TextBody2"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="12dp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_early_notification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"/>

            </LinearLayout>

            <!-- Vibration -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_vibration"
                    app:tint="@color/text_secondary"
                    android:contentDescription="@string/vibration"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/vibration"
                        android:textAppearance="@style/TextBody1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/haptic_feedback_on_alert"
                        android:textAppearance="@style/TextCaption"/>

                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_vibration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>

            </LinearLayout>

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_reminder"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/save_reminder"
                android:textAppearance="@style/TextButton"
                android:background="@drawable/bg_rounded_button_primary"
                app:backgroundTint="@color/primary"
                app:cornerRadius="12dp"/>

            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:text="@string/cancel"
                android:textAppearance="@style/TextBody1"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/btn_delete_reminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:text="@string/delete_reminder"
                android:textAppearance="@style/TextBody1"
                android:textColor="@color/error_red"
                android:visibility="gone"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/surface"
        android:elevation="10dp"
        app:itemActiveIndicatorStyle="@style/App.ActiveIndicator"
        app:itemIconSize="24dp"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemRippleColor="@color/success_light"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
