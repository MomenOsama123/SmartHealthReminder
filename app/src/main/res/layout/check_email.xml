عه<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5EE"
    android:orientation="vertical"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:paddingTop="48dp"
    android:paddingBottom="48dp">

    <!-- Back Arrow -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/arrow_back"
        android:clickable="true"
        android:focusable="true" />

    <!-- Center Content -->

    <!-- ECG Line at Bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="500dp"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Success Icon Circle -->

        <!-- Title -->

        <FrameLayout
            android:layout_width="150dp"
            android:layout_height="200dp"
            android:background="@drawable/check_mark_email">


        </FrameLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            android:text="@string/check_your_email"
            android:textColor="#1A2E2A"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/password_recovery_link"
            android:textColor="#6B7B75"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/ivEcgLine"
            android:layout_width="182dp"
            android:layout_height="50dp"
            android:alpha="0.4"
            android:scaleType="fitXY"
            android:src="@drawable/ic_ecg_line" />

    </LinearLayout>

</LinearLayout>