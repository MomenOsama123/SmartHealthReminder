<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_alarm_ringing"
    tools:ignore="LayoutFidelity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_alarm_category"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text=""
            tools:text="Medication"
            android:textAppearance="@style/TextBody1"
            android:textColor="@color/text_on_primary"
            android:drawablePadding="8dp"
            app:drawableStartCompat="@drawable/ic_category_with_bg"
            android:contentDescription="@string/category_icon"
            tools:ignore="ImageContrastCheck" />

        <TextView
            android:id="@+id/tv_alarm_priority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            tools:text="High"
            android:textAppearance="@style/TextCaption"
            android:textColor="@color/text_on_primary"
            android:background="@drawable/bg_rounded_card_red"
            android:backgroundTint="#40FFFFFF"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"/>

    </LinearLayout>

    <!-- Bell Icon -->
    <ImageView
        android:id="@+id/iv_bell"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_bell"
        app:tint="@color/text_on_primary"
        android:alpha="0.3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/time_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        android:contentDescription="@string/alarm_bell"
        tools:ignore="ImageContrastCheck" />

    <!-- Time -->
    <LinearLayout
        android:id="@+id/time_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/iv_bell"
        app:layout_constraintBottom_toTopOf="@id/tv_alarm_date"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp">

        <TextView
            android:id="@+id/tv_alarm_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            tools:text="08:30"
            android:textAppearance="@style/TextHeading1"
            android:textSize="72sp"
            android:textColor="@color/text_on_primary"/>

    </LinearLayout>

    <!-- Date -->
    <TextView
        android:id="@+id/tv_alarm_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        tools:text="Monday, June 15, 2025"
        android:textAppearance="@style/TextCaption"
        android:textColor="@color/text_on_primary"
        android:alpha="0.8"
        app:layout_constraintTop_toBottomOf="@id/time_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Info Container -->
    <LinearLayout
        android:id="@+id/info_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tv_alarm_date"
        app:layout_constraintBottom_toTopOf="@id/btn_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp"
        android:layout_marginHorizontal="32dp">

        <TextView
            android:id="@+id/tv_alarm_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            tools:text="Morning Medication"
            android:textAppearance="@style/TextHeading2"
            android:textColor="@color/text_on_primary"/>

        <TextView
            android:id="@+id/tv_patient_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            tools:text="Eleanor Vance"
            android:textAppearance="@style/TextBody1"
            android:textColor="@color/text_on_primary"
            android:alpha="0.9"/>

        <TextView
            android:id="@+id/tv_room_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            tools:text="Room 302"
            android:textAppearance="@style/TextBody2"
            android:textColor="@color/text_on_primary"
            android:alpha="0.7"/>

    </LinearLayout>

    <!-- Buttons Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/btn_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_snooze"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/snooze"
            android:textAppearance="@style/TextButton"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_rounded_button_white"
            app:backgroundTint="@color/surface"
            app:cornerRadius="12dp"
            app:layout_constraintWidth_max="320dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_stop_alarm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/stop_alarm"
            android:textAppearance="@style/TextButton"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_rounded_button_white"
            app:backgroundTint="@color/surface"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_check"
            app:iconTint="@color/primary"
            app:iconGravity="textStart"
            app:layout_constraintWidth_max="320dp"
            app:layout_constraintTop_toBottomOf="@id/btn_snooze"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>