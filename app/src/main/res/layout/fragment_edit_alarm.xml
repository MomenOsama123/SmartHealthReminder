<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/back"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/edit_alarm"
                android:textAppearance="@style/TextHeading3"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="@string/clinical_alarms"
                android:textAppearance="@style/TextBody2"
                android:textColor="@color/primary"/>

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Time Picker Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_hour"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textAppearance="@style/TextHeading1"
                            android:textSize="48sp"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/for_time1"
                            android:textAppearance="@style/TextHeading1"
                            android:textSize="48sp"
                            android:textColor="@color/text_tertiary"/>

                        <TextView
                            android:id="@+id/tv_minute"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textAppearance="@style/TextHeading1"
                            android:textSize="48sp"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:id="@+id/tv_am_pm_display"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text=""
                            android:textAppearance="@style/TextBody1"
                            android:textColor="@color/text_secondary"/>

                    </LinearLayout>

                    <!-- Time Slider Placeholder -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_prev_hour"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textAppearance="@style/TextBody2"
                            android:textColor="@color/text_tertiary"/>

                        <View
                            android:layout_width="40dp"
                            android:layout_height="2dp"
                            android:layout_marginHorizontal="8dp"
                            android:background="@color/primary"/>

                        <TextView
                            android:id="@+id/tv_prev_minute"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textAppearance="@style/TextBody2"
                            android:textColor="@color/text_tertiary"/>

                        <View
                            android:layout_width="40dp"
                            android:layout_height="2dp"
                            android:layout_marginHorizontal="8dp"
                            android:background="@color/primary"/>

                        <TextView
                            android:id="@+id/tv_prev_am_pm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textAppearance="@style/TextBody2"
                            android:textColor="@color/text_tertiary"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Repeat Days -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/repeat_days"
                android:textAppearance="@style/TextCaption"
                android:textAllCaps="true"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/day_sun"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_day_circle_unselected"
                    android:gravity="center"
                    android:text="@string/sunday"
                    android:textAppearance="@style/TextBody2"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/day_mon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_day_circle_unselected"
                    android:gravity="center"
                    android:text="@string/monday"
                    android:textAppearance="@style/TextBody2"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/day_tue"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_day_circle_unselected"
                    android:gravity="center"
                    android:text="@string/tuesday"
                    android:textAppearance="@style/TextBody2"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/day_wed"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_day_circle_unselected"
                    android:gravity="center"
                    android:text="@string/wednesday"
                    android:textAppearance="@style/TextBody2"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/day_thu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_day_circle_unselected"
                    android:gravity="center"
                    android:text="@string/thursday"
                    android:textAppearance="@style/TextBody2"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/day_fri"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_day_circle_unselected"
                    android:gravity="center"
                    android:text="@string/friday"
                    android:textAppearance="@style/TextBody2"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/day_sat"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_day_circle_unselected"
                    android:gravity="center"
                    android:text="@string/saturday"
                    android:textAppearance="@style/TextBody2"
                    android:textColor="@color/text_secondary"/>

            </LinearLayout>

            <!-- Alarm Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/alarm_label"
                android:textAppearance="@style/TextCaption"
                android:textAllCaps="true"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_alarm_label"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:autofillHints="Alarm"
                android:background="@drawable/bg_input_field"
                android:hint="@string/enter_alarm_label"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textAppearance="@style/TextBody1"
                android:layout_marginBottom="24dp"
                tools:ignore="Autofill,TextFields" />



            <!-- Vibration -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/vibration"
                    android:textAppearance="@style/TextBody1"/>

                <TextView
                    android:id="@+id/tv_vibration_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textAppearance="@style/TextBody2"
                    android:layout_marginEnd="12dp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_vibration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>

            </LinearLayout>

            <!-- Gradual Volume -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/gradual_volume_increase"
                        android:textAppearance="@style/TextBody1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/starts_softly_and_increases_over_2_minutes"
                        android:textAppearance="@style/TextCaption"/>

                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_gradual"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>



            </LinearLayout>

            <!-- Save Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_alarm"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/save_alarm_protocol"
                android:textAllCaps="false"
                android:textColor="@color/primary_green"
                android:textStyle="bold"
                android:textSize="16sp"
                app:backgroundTint="?attr/colorSurface"
                app:cornerRadius="12dp"
                app:strokeColor="@color/primary_green"
                app:strokeWidth="2dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_alarm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:text="@string/delete_alarm"
                android:textAllCaps="false"
                android:textColor="@color/missed"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="?attr/colorSurface"
                app:cornerRadius="12dp"
                app:strokeColor="@color/missed"
                app:strokeWidth="2dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
