<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="28dp"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_bottom_sheet_handle"/>

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="@string/quick_access"
        android:textAppearance="@style/TextHeading3"
        android:textColor="@color/text_primary"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="@string/go_to_a_section_to_manage_your_health_data"
        android:textAppearance="@style/TextCaption"
        android:textColor="@color/text_tertiary"/>

    <!-- 2-column grid of cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="12dp">

        <!-- Reminders card -->
        <LinearLayout
            android:id="@+id/action_add_reminder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:background="@drawable/bg_quick_action_card"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_tool_bg"
                android:padding="10dp"
                android:src="@drawable/ic_pill"
                android:layout_marginBottom="10dp"
                app:tint="@color/primary"
                android:contentDescription="@string/reminders"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_reminder"
                android:textAppearance="@style/TextBody1"
                android:textColor="@color/text_primary"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/set_a_new_reminder"
                android:textAppearance="@style/TextCaption"
                android:textColor="@color/text_tertiary"
                android:gravity="center"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Alarms card -->
        <LinearLayout
            android:id="@+id/action_add_alarm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:background="@drawable/bg_quick_action_card"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_tool_bg"
                android:padding="10dp"
                android:src="@drawable/ic_bell"
                android:layout_marginBottom="10dp"
                app:tint="@color/urgent"
                android:contentDescription="@string/alarms"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_alarm"
                android:textAppearance="@style/TextBody1"
                android:textColor="@color/text_primary"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/set_a_new_alarm"
                android:textAppearance="@style/TextCaption"
                android:textColor="@color/text_tertiary"
                android:gravity="center"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:weightSum="2">

        <!-- Reports card -->
        <LinearLayout
            android:id="@+id/action_add_report"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:background="@drawable/bg_quick_action_card"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_tool_bg"
                android:padding="10dp"
                android:src="@drawable/ic_chart"
                android:layout_marginBottom="10dp"
                app:tint="@color/primary_dark"
                android:contentDescription="@string/reports"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_report"
                android:textAppearance="@style/TextBody1"
                android:textColor="@color/text_primary"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upload_health_report"
                android:textAppearance="@style/TextCaption"
                android:textColor="@color/text_tertiary"
                android:gravity="center"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Dashboard card -->
        <LinearLayout
            android:id="@+id/action_view_dashboard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:background="@drawable/bg_quick_action_card"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/circle_tool_bg"
                android:padding="10dp"
                android:src="@drawable/dashboard"
                android:layout_marginBottom="10dp"
                app:tint="@color/success"
                android:contentDescription="@string/dashboard"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/view_dashboard"
                android:textAppearance="@style/TextBody1"
                android:textColor="@color/text_primary"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/your_health_overview"
                android:textAppearance="@style/TextCaption"
                android:textColor="@color/text_tertiary"
                android:gravity="center"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
