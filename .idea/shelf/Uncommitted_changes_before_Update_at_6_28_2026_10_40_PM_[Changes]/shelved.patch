+    fun getMedicationStats(userId: Int, date: String): MedicationStats {
+        val db = readableDatabase
+        val totalCursor = db.rawQuery(
+            "SELECT COUNT(*) FROM daily_doses WHERE user_id = ? AND dose_date = ?",
