+        if (totalCursor.moveToFirst()) total = totalCursor.getInt(0)
+        if (takenCursor.moveToFirst()) taken = takenCursor.getInt(0)
+        if (missedCursor.moveToFirst()) missed = missedCursor.getInt(0)
+        totalCursor.close()
